# ─── 이거돼? 환경변수 설정 ──────────────────────────────────────────────────
# 이 파일을 복사하여 .env 파일을 생성하고 실제 값을 입력하세요
# cp .env.example .env

# ─── Groq API (서버 전용 — 클라이언트 번들에 노출 금지) ─────────────────────
# https://console.groq.com/keys 에서 발급
# /api/groq-proxy 서버리스 함수가 이 키로 Groq API를 호출합니다.
GROQ_API_KEY=your_groq_api_key_here

# ─── 식약처(MFDS) API ───────────────────────────────────────────────────────
# https://www.data.go.kr 에서 발급 (낱알식별, 의약품개요, 제품허가 3종 활용 신청)
# 서버 전용 키 (api/mfds-proxy.js 가 사용). VITE_ prefix 없음
MFDS_API_KEY=your_mfds_api_key_here

# ─── Firebase 설정 ──────────────────────────────────────────────────────────
# https://console.firebase.google.com 에서 프로젝트 생성 후 웹 앱 추가
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ─── 앱 설정 ────────────────────────────────────────────────────────────────
# Firestore 경로에 사용되는 앱 식별자
VITE_APP_ID=igeordwae-production
